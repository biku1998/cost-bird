{
  "name": "cost-bird",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloud cost co-pilot — AWS-only POC (NL→SQL agent over normalized billing data)",
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:setup-readonly": "tsx lib/db/setup-readonly.ts",
    "etl": "tsx scripts/etl/index.ts",
    "etl:describe": "tsx scripts/etl/describe.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.84",
    "@ai-sdk/react": "3.0.207",
    "@mastra/core": "1.42.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "ai": "6.0.205",
    "dotenv": "17.4.2",
    "next": "16.2.9",
    "pg": "8.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@duckdb/node-api": "1.5.3-r.3",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "25.9.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.15",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@duckdb/node-bindings",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  }
}
