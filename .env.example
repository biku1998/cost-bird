# ── AWS / CUR 2.0 Data Export (source) ────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
CUR_S3_BUCKET=cloud-bird-billing-export
CUR_S3_PREFIX=cur/

# ── Postgres (local Docker; see docker-compose.yml) ───────────────
# Full-access role: used by Prisma for migrations + the ETL load.
DATABASE_URL=postgresql://costbird:costbird@localhost:5432/costbird
# Read-only role: used by the NL→SQL agent to execute generated SQL.
DATABASE_URL_READONLY=postgresql://costbird_ro:costbird_ro@localhost:5432/costbird

# ── Agent (Anthropic) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Default model for the NL→SQL agent.
AGENT_MODEL=claude-sonnet-4-6

# ── Alerts ────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
